<body>
<head>Large <s xml:lang="en"><hi>Khecaryabhyāsakrama</hi> (in chapter 3)</s></head>    <div type="altrec">
<lg xml:id="hp03_032_01">
 <l><app><lem/><rdg wit="#V15 #Jyo">also included in</rdg></app><s type="pada"><app><lem wit="#J6 #Jyo">snuhī</lem><rdg wit="#V15 #E4">snuhi</rdg><rdg wit="#V3">śnuhi</rdg></app>pattranibhaṃ śastraṃ</s> <s type="pada">sutīkṣṇaṃ snigdhanirmalam/</s></l>
<l> <s type="pada">samādāya tatas tena</s> <s type="pada">romamātraṃ <app><lem wit="#V3">samucchidet</lem><rdg wit="#V15 #E4 #Jyo">samucchinet</rdg><rdg wit="#J6">samucchiṃdyāt</rdg></app>//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_2">
 <l><app><lem/><rdg wit="#V15 #Jyo">also included in</rdg></app><s type="pada"><app><lem wit="#V15 #Gr6">kṛtvā</lem><rdg wit="#Jyo">tataḥ</rdg></app> saindhava<app><lem wit="#Jyo">pathyābhyāṃ</lem><rdg wit="#J6 #E4 #V3">pathyādi</rdg><rdg wit="#V15">pakṣyādi</rdg></app></s> <s type="pada">cūrṇitābhyāṃ pragharṣayet/</s></l>
<l>punaḥ saptadine prāpte <s type="pada">romamātraṃ <app><lem wit="#E4 #V3">samucchidet</lem><rdg wit="#Jyo">samucchinet</rdg><rdg wit="#V15">punaḥ chidet</rdg><rdg wit="#J6">samutthiyāt</rdg></app>//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_3">
 <l><app><lem/><rdg wit="#V15 #Jyo">also included in</rdg></app><s type="pada">evaṃ krameṇa <app><lem wit="#J6 #E4 #V3 #Jyo">ṣaṇmāsaṃ</lem><rdg wit="#V15">ṣaṇmāsān</rdg></app></s> <s type="pada"><app><lem wit="#J6 #V15 #E4 #V3">nitya</lem><rdg wit="#Jyo">nityaṃ</rdg></app><app><lem wit="#V15 #E4 #V3">yuktaṃ</lem><rdg wit="#Jyo">yuktaḥ</rdg><rdg wit="#J6">muktaṃ</rdg></app> samācaret/</s></l>
<l> <s type="pada"><app><lem wit="#Gr6 #Jyo">ṣaṇmāsā<seg type="deva-ignore">d</seg></lem><rdg wit="#V15">ṣaṇmāse</rdg></app>d rasanā<app><lem wit="#J6 #E4 #V3 #Jyo">mūla</lem><rdg wit="#V15">mūlaṃ</rdg></app></s><s type="pada"><app><lem wit="#E4pc">śirābandhaṃ</lem><rdg wit="#V15 #Jyo">śirābandhaḥ</rdg><rdg wit="#E4ac #V3">śarābandhaṃ</rdg><rdg wit="#J6">śarabaṃdhaṃ</rdg></app> <app><lem wit="#Gr6">vinaśyati</lem><rdg wit="#V15 #Jyo">praṇaśyati</rdg></app>//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_4">
 <l><s type="pada">atha vāgīśvarīdhāma</s><s type="pada">śiro vastreṇa veṣṭayet/</s></l>
<l> <s type="pada">śanair utkarṣayed yogī</s> <s type="pada">kālavelāvidhānavit//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_5">
 <l><app><lem/><rdg><s xml:lang="en">= 3.95*2</s></rdg></app><s type="pada">vitasti<app><lem wit="#V3 #J6">pramitaṃ</lem><rdg wit="#E4">pratimaṃ</rdg></app> <app><lem wit="#E4 #V3">dairghyaṃ</lem><rdg wit="#J6pc">dairghye</rdg><rdg wit="#J6ac">dairghya</rdg></app></s> <s type="pada">vistāraṃ <app><lem wit="#V3 #J6">caturaṅgulam</lem><rdg wit="#E4">caturāṅgulam</rdg></app>/</s></l>
<l> <s type="pada">mṛdulaṃ dhavalaṃ proktaṃ</s> <s type="pada">veṣṭitāmbaralakṣaṇam//</s>  <anchor xml:id="III33-5"/></l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_6">
 <l><s type="pada">punaḥ ṣaṇmāsamātreṇa</s> <s type="pada"><app><lem resp="ego">nitya</lem><rdg wit="#E4 #V3 #J6">punaḥ</rdg></app>saṃkarṣaṇāt priye/</s></l>
<l> <s type="pada">bhrūmadhyāvadhi vardheta</s> <s type="pada">tiryak karṇabilāvadhi//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_7">
 <l><s type="pada">adhastā<app><lem wit="#J6"><seg type="ltn-ignore">c </seg>cibukaṃ mūlaṃ</lem><rdg wit="#E4">cibukaṃ mūla</rdg><rdg wit="#V3">cibukamūla</rdg></app></s> <s type="pada">prayāti kramakāritā/</s></l>
<l> <s type="pada"><app><lem resp="ego">keśāntam ūrdhvaṃ</lem><rdg wit="#E4 #V3 #J6">krośād ūrdhvaṃ ca</rdg></app> <app><lem wit="#E4 #V3">kramati</lem><rdg wit="#J6">krāmati</rdg></app></s> <s type="pada">tiryak <app><lem resp="ego">śaṅkhāvadhi</lem><rdg wit="#E4 #V3 #J6">saṃkhyāvadhi</rdg></app> priye//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_8">
 <l><s type="pada">punaḥ saṃvatsarād devi</s> <s type="pada"><app><lem resp="ego">dvitīyā<seg type="deva-ignore">c</seg></lem><rdg wit="#E4 #V3 #J6">dvitīyā</rdg></app>c caiva līlayā/</s></l>
<l> <s type="pada">brahmarandhrāntam āvṛtya</s> <s type="pada">tiṣṭhet paramavandite//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_9">
<l><s type="pada">svatālumūlaṃ saṃghṛṣya</s> <s type="pada">saptavāsara<app><lem resp="ego"><seg type="ltn-ignore">m </seg>ātmavit</lem><rdg wit="#E4 #V3 #J6">ātmani</rdg></app>/</s></l>
<l> <s type="pada">svagurūktaprakāreṇa</s> <s type="pada">malaṃ sarvaṃ viśoṣayet//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_10">
<l><s type="pada">aṅgulyagreṇa saṃghṛṣya</s> <s type="pada">jihvāṃ tatra niveśayet/</s></l>
<l> <s type="pada">śanaiḥ śanair mastakāc ca</s> <s type="pada">mahāvajrakapāṭabhit//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_11">
<l><s type="pada">pūrva<app><lem wit="#E4">bīja</lem><rdg wit="#V3">vīya</rdg><rdg wit="#J6">vīrya</rdg></app>yutāṃ vidyāṃ</s> <s type="pada">vyākhyātām atidurlabhām/</s></l>
<l> <s type="pada">asyāḥ ṣaḍaṅgaṃ kurvīta</s> <s type="pada">tayā ṣaṭcakrabhinnayā//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_12">
<l><s type="pada">khe nirastasakalakriyākrame</s></l>
<l> <s type="pada"><app><lem resp="ego">yā citiś carati</lem><rdg wit="#E4">yā citaś carati</rdg><rdg wit="#V3">yā cittaś carati</rdg><rdg wit="#J6">ṇa cittaś carati</rdg></app> śāśvatodaye/</s></l>
<l> <s type="pada">sā śivatva<app><lem wit="#E4 #V3">samavāya</lem><rdg wit="#J6">samavāyi</rdg></app><app><lem wit="#E4 #J6">kāriṇī</lem><rdg wit="#V3">kariṇī</rdg></app></s></l>
<l> <s type="pada">khecarī <app><lem wit="#E4 #V3">ca bhava</lem><rdg wit="#J6">{{ca}} bhavati</rdg></app>khedahāriṇī//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_13">
<l><s type="pada">krameṇaiva <app><lem wit="#E4 #V3">prakartavyā</lem><rdg wit="#J6">pravartavyā</rdg></app></s><s type="pada">bhyāsena <app><lem wit="#E4 #V3">varavarṇini</lem><rdg wit="#J6">paravarṇinī</rdg></app>/</s></l>
<l> <s type="pada">yugapa<app><lem wit="#E4 #V3 #J6pc"><seg type="ltn-ignore">d </seg>yatate</lem><rdg wit="#J6ac">yatete</rdg></app> tasya</s> <s type="pada">śarīraṃ vilayaṃ vrajet//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_14">
<l><s type="pada">tasmāc chanaiḥ śanaiḥ kāryo</s><s type="pada">’bhyāso na yugapat priye/</s></l>
<l> <s type="pada"><app><lem wit="#J6">evaṃ</lem><rdg wit="#E4 #V3">eva</rdg></app> varṣatrayaṃ kṛtvā</s> <s type="pada">brahmadvāraṃ <app><lem wit="#E4 #J6">viśe<seg type="deva-ignore">d</seg></lem><rdg wit="#V3">biśe</rdg></app>d dhruvam//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_15">
<l><s type="pada">ṣaṭcakrāṇi vibhidya śakti<app><lem wit="#E4pc #J6">bhujagīṃ</lem><rdg wit="#E4ac #V3">bhujaṃgī</rdg></app> <app><lem wit="#E4 #V3">protthāpya</lem><rdg wit="#J6">protthāya</rdg></app> mūlasthitāṃ</s></l>
<l> <s type="pada">bhittvā granthitrayaṃ ca paścimaśirāprākārarūpaṃ mahat/</s></l>
<l> <s type="pada">nītvā prāṇam ataḥ śirobilam alaṃ nirmathya cittena tat</s></l>
<l> <s type="pada"><app><lem wit="#J6">liṅgaṃ</lem><rdg wit="#E4 #V3">taliṅgaṃ</rdg></app> yaḥ <app><lem wit="#J6">pibatī</lem><rdg wit="#E4 #V3">pibate</rdg></app>ndumaṇḍalagalan muktaḥ <app><lem wit="#E4 #V3">sa</lem><rdg wit="#J6">ca</rdg></app> sākṣācchivaḥ//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_16">
<l><s type="pada">nityaṃ <app><lem wit="#E4 #V3">yas tūrdhva</lem><rdg wit="#J6">yasphūrja</rdg></app><app><lem wit="#E4">jihvo yadi</lem><rdg wit="#V3">jihvogradi</rdg><rdg wit="#J6">jihvāgrayā</rdg></app> pibati pumān saptadhārāmṛ<app><lem wit="#E4 #V3 #J6pc"><seg type="deva-ignore">°</seg>taughaṃ</lem><rdg wit="#J6ac">tauccaṃ</rdg></app></s></l>
<l> <s type="pada"><app><lem wit="#E4 #V3">susvādaṃ</lem><rdg wit="#J6">su[kha]daṃ</rdg></app> śītalāṅgaṃ duritabhayaharaṃ kṣutpipāsānivāri/</s></l>
<l> <s type="pada">piṇḍasthairyaṃ hi tasmād bhavati <app><lem resp="ego">mṛtapathā</lem><rdg wit="#E4 #V3">mṛtayathā</rdg><rdg wit="#J6">mṛtaṃ yathā</rdg></app> mṛtyurogā<app><lem wit="#E4 #V3"><seg type="ltn-ignore">d </seg>bhavanti</lem><rdg wit="#J6">bhavati</rdg></app></s></l>
<l> <s type="pada"><app><lem wit="#J6">daurbhāgyaṃ</lem><rdg wit="#E4 #V3">daurbhyāgyaṃ</rdg></app> yāti nāśaṃ prasarati sakalaṃ yāti <app><lem wit="#E4 #V3">kālaṃ</lem><rdg wit="#J6">kālo</rdg></app> bhramitvā//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_17">
<l><s type="pada"><app><lem wit="#J6">tīkṣṇakaṃ</lem><rdg wit="#E4 #V3">tīkṣṇake</rdg></app> harate vyādhiṃ</s> <s type="pada">kaṭukaṃ kuṣṭhanāśanam/</s></l>
<l> <s type="pada">ghṛtasvādūpamaṃ caiva</s> <s type="pada">amaratvaṃ <app><lem wit="#E4 #V3">labhe<seg type="deva-ignore">d</seg></lem><rdg wit="#J6">labhate</rdg></app>d dhruvam//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_18">
<l><s type="pada">madhusvādūpamaṃ caiva</s> <s type="pada">śāstra<app><lem wit="#E4 #V3"><seg type="ltn-ignore">m </seg>udgirate</lem><rdg wit="#J6">udgirati</rdg></app> <app><lem wit="#E4 #J6">bahu</lem><rdg wit="#V3">bahuḥ</rdg></app>/</s></l>
<l> <s type="pada">†<app><lem resp="ego">laḍḍu</lem><rdg wit="#E4 #V3 #J6">laḍu</rdg></app><app><lem wit="#E4 #V3">ṣaṇḍaka</lem><rdg wit="#J6">khaṃḍaka</rdg></app><app><lem resp="ego">khādyāni</lem><rdg wit="#E4 #V3">pādyāni</rdg><rdg wit="#J6">pādyāni</rdg></app></s> <s type="pada"><app><lem wit="#E4 #V3">pakvānnāni</lem><rdg wit="#J6">pakvānnāny apy</rdg></app> anekaśaḥ†//</s>  </l> 
</lg>
</div> <div type="altrec">
<lg xml:id="hp03_032_19">
<l><s type="pada">divyakalpaṃ <app><lem wit="#E4 #V3">rame<seg type="deva-ignore">n</seg></lem><rdg wit="#J6">krīḍen</rdg></app>n nityam</s> <s type="pada">utkṛṣṭo jāyate dhruvam/</s></l>
<l> <s type="pada">tanmayatvam avāpnoti</s> <s type="pada"><app><lem wit="#J6">kośakārīva</lem><rdg wit="#V3">kauśakārīva</rdg><rdg wit="#E4">kauṣṭakārīva</rdg></app> kīṭakaḥ//</s>  </l> 
</lg>
